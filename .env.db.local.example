# BrainBrew — PRIVILEGED credentials for remote database + function tooling.
#
# Copy this to `.env.db.local` (git-ignored) and fill in real values, OR export
# these in your shell. NEVER commit real values. The Expo app never reads this.
#
# Get them from the Supabase dashboard:
#   Access token:  https://supabase.com/dashboard/account/tokens   (sbp_...)
#   Secret key:    Project Settings → API keys → Secret keys        (sb_secret_...)
#   DB password:   Project Settings → Database → the password you set

SUPABASE_ACCESS_TOKEN=sbp_your_access_token_here
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
SUPABASE_DB_PASSWORD=your_database_password_here

# Function secret (any long random string; used to sign attempt tokens).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ATTEMPT_TOKEN_SECRET=generate_a_32_byte_random_string_here
